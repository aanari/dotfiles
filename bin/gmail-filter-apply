#!/usr/bin/env python3

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

LABEL_COLORS = {
    "Infra": {"textColor": "#0b804b", "backgroundColor": "#b9e4d0"},
    "Logistics": {"textColor": "#1c4587", "backgroundColor": "#c9daf8"},
    "Receipts": {"textColor": "#a46a21", "backgroundColor": "#fce8b3"},
    "Notifications": {"textColor": "#653e9b", "backgroundColor": "#e4d7f5"},
    "Updates": {"textColor": "#285bac", "backgroundColor": "#b6cff5"},
    "Newsletters": {"textColor": "#b65775", "backgroundColor": "#fcdee8"},
    "Promotions": {"textColor": "#cc3a21", "backgroundColor": "#f6c5be"},
    "Calendar": {"textColor": "#0b804b", "backgroundColor": "#b9e4d0"},
}

FALLBACK_LABEL_COLORS = [
    {"textColor": "#0b804b", "backgroundColor": "#b9e4d0"},
    {"textColor": "#1c4587", "backgroundColor": "#c9daf8"},
    {"textColor": "#a46a21", "backgroundColor": "#fce8b3"},
    {"textColor": "#653e9b", "backgroundColor": "#e4d7f5"},
    {"textColor": "#b65775", "backgroundColor": "#fcdee8"},
    {"textColor": "#cc3a21", "backgroundColor": "#f6c5be"},
]


def run_gws_json(args):
    env = os.environ.copy()
    env.setdefault("GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND", "file")
    result = subprocess.run(
        ["gws", *args, "--format", "json"],
        check=False,
        capture_output=True,
        text=True,
        env=env,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)
    payload = result.stdout.strip()
    if not payload:
        return {}
    return json.loads(payload)


def load_rules(path_arg):
    if path_arg == "-":
        return json.load(sys.stdin)
    return json.loads(Path(path_arg).read_text())


def normalize_criteria(rule):
    if "criteria" in rule:
        criteria = dict(rule["criteria"])
    elif "query" in rule:
        criteria = {"query": rule["query"]}
    else:
        raise SystemExit("Each rule must include either 'criteria' or 'query'.")

    normalized = {}
    for key in ("from", "to", "subject", "query", "negatedQuery", "hasAttachment", "excludeChats", "size", "sizeComparison"):
        if key in criteria and criteria[key] not in (None, ""):
            normalized[key] = criteria[key]
    if not normalized:
        raise SystemExit("Each rule must keep at least one non-empty filter criterion.")
    return normalized


def normalize_rule(rule):
    if "label" not in rule:
        raise SystemExit("Each rule must include 'label'.")
    return {
        "criteria": normalize_criteria(rule),
        "label": rule["label"],
        "archive": bool(rule.get("archive", True)),
    }


def criteria_signature(criteria):
    return json.dumps({key: criteria[key] for key in sorted(criteria)}, sort_keys=True, separators=(",", ":"))


def criteria_to_query(criteria):
    parts = []

    def quote(value):
        if isinstance(value, bool):
            return ""
        value = str(value)
        if not value:
            return ""
        if any(ch.isspace() for ch in value):
            return '"' + value.replace('"', '\\"') + '"'
        return value

    if criteria.get("from"):
        parts.append(f'from:{quote(criteria["from"])}')
    if criteria.get("to"):
        parts.append(f'to:{quote(criteria["to"])}')
    if criteria.get("subject"):
        parts.append(f'subject:{quote(criteria["subject"])}')
    if criteria.get("query"):
        parts.append(f'({criteria["query"]})')
    if criteria.get("negatedQuery"):
        parts.append(f'-({criteria["negatedQuery"]})')
    if criteria.get("hasAttachment"):
        parts.append("has:attachment")
    if criteria.get("excludeChats"):
        parts.append("-is:chat")
    if criteria.get("sizeComparison") and criteria.get("size") is not None:
        op = "larger" if criteria["sizeComparison"] == "larger" else "smaller"
        parts.append(f"{op}:{criteria['size']}")

    parts.append("in:inbox")
    return " ".join(part for part in parts if part)


def pick_label_color(label_name, labels_by_name):
    if label_name in LABEL_COLORS:
        return LABEL_COLORS[label_name]
    used = {
        json.dumps(item.get("color", {}), sort_keys=True)
        for item in labels_by_name.values()
        if item.get("type") == "user" and item.get("color")
    }
    for color in FALLBACK_LABEL_COLORS:
        signature = json.dumps(color, sort_keys=True)
        if signature not in used:
            return color
    return FALLBACK_LABEL_COLORS[0]


def ensure_label(label_name, labels_by_name, apply):
    if label_name in labels_by_name:
        return labels_by_name[label_name]["id"], False
    if not apply:
        return None, True
    color = pick_label_color(label_name, labels_by_name)
    payload = run_gws_json(
        [
            "gmail",
            "users",
            "labels",
            "create",
            "--params",
            json.dumps({"userId": "me"}),
            "--json",
            json.dumps(
                {
                    "name": label_name,
                    "labelListVisibility": "labelShow",
                    "messageListVisibility": "show",
                    "color": color,
                }
            ),
        ]
    )
    labels_by_name[label_name] = payload
    return payload["id"], True


def filter_exists(existing_filters, criteria, label_id, archive):
    wanted_remove = sorted(["INBOX"] if archive else [])
    wanted_add = sorted([label_id])
    for item in existing_filters:
        action = item.get("action", {})
        if criteria_signature(item.get("criteria", {})) != criteria_signature(criteria):
            continue
        if sorted(action.get("addLabelIds", [])) != wanted_add:
            continue
        if sorted(action.get("removeLabelIds", [])) != wanted_remove:
            continue
        return True
    return False


def list_matching_inbox_message_ids(criteria):
    ids = []
    page_token = None
    query = criteria_to_query(criteria)

    while True:
        params = {"userId": "me", "q": query, "maxResults": 500}
        if page_token:
            params["pageToken"] = page_token
        payload = run_gws_json(
            ["gmail", "users", "messages", "list", "--params", json.dumps(params)]
        )
        ids.extend(item["id"] for item in payload.get("messages", []))
        page_token = payload.get("nextPageToken")
        if not page_token:
            break

    return ids


def chunked(items, size):
    for idx in range(0, len(items), size):
        yield items[idx:idx + size]


def retroactively_apply_rule(ids, label_id, archive):
    if not ids:
        return 0

    for batch in chunked(ids, 1000):
        body = {
            "ids": batch,
            "addLabelIds": [label_id],
            "removeLabelIds": ["INBOX"] if archive else [],
        }
        run_gws_json(
            [
                "gmail",
                "users",
                "messages",
                "batchModify",
                "--params",
                json.dumps({"userId": "me"}),
                "--json",
                json.dumps(body),
            ]
        )

    return len(ids)


def main():
    parser = argparse.ArgumentParser(description="Create Gmail filters from reviewed JSON rules.")
    parser.add_argument("rules", help="Path to JSON rules file, or - for stdin.")
    parser.add_argument("--apply", action="store_true", help="Actually create missing labels and filters.")
    args = parser.parse_args()

    payload = load_rules(args.rules)
    rules = payload["rules"] if isinstance(payload, dict) and "rules" in payload else payload
    rules = [normalize_rule(rule) for rule in rules]

    labels_payload = run_gws_json(
        ["gmail", "users", "labels", "list", "--params", json.dumps({"userId": "me"})]
    )
    filters_payload = run_gws_json(
        ["gmail", "users", "settings", "filters", "list", "--params", json.dumps({"userId": "me"})]
    )
    labels_by_name = {item["name"]: item for item in labels_payload.get("labels", [])}
    existing_filters = filters_payload.get("filter", [])

    for rule in rules:
        label_id, created_label = ensure_label(rule["label"], labels_by_name, args.apply)
        status_bits = []
        if created_label:
            status_bits.append("create-label")
        matching_inbox_count = 0
        if label_id is None:
            status_bits.append("needs-label")
        elif filter_exists(existing_filters, rule["criteria"], label_id, rule["archive"]):
            status_bits.append("filter-exists")
        else:
            status_bits.append("create-filter")
            if args.apply:
                body = {
                    "criteria": rule["criteria"],
                    "action": {"addLabelIds": [label_id]},
                }
                if rule["archive"]:
                    body["action"]["removeLabelIds"] = ["INBOX"]
                created_filter = run_gws_json(
                    [
                        "gmail",
                        "users",
                        "settings",
                        "filters",
                        "create",
                        "--params",
                        json.dumps({"userId": "me"}),
                        "--json",
                        json.dumps(body),
                    ]
                )
                existing_filters.append(created_filter)

        if label_id is not None:
            matching_ids = list_matching_inbox_message_ids(rule["criteria"])
            matching_inbox_count = len(matching_ids)
            if matching_inbox_count:
                status_bits.append(f"backfill:{matching_inbox_count}")
                if args.apply:
                    retroactively_apply_rule(matching_ids, label_id, rule["archive"])

        print(
            json.dumps(
                {
                    "label": rule["label"],
                    "criteria": rule["criteria"],
                    "archive": rule["archive"],
                    "matching_inbox_count": matching_inbox_count,
                    "status": status_bits,
                    "apply": args.apply,
                }
            )
        )


if __name__ == "__main__":
    main()
