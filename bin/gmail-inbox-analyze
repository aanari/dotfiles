#!/usr/bin/env python3

import argparse
import concurrent.futures
import json
import os
import re
import subprocess
import sys
from collections import Counter, defaultdict
from datetime import datetime
from email.utils import parseaddr
from pathlib import Path


HEADER_NAMES = [
    "From",
    "Subject",
    "Date",
    "List-Id",
    "List-Unsubscribe",
    "Precedence",
    "Sender",
    "Reply-To",
]

CATEGORY_PRIORITY = {
    "Infra": 7,
    "Logistics": 6,
    "Receipts": 5,
    "Notifications": 4,
    "Updates": 3,
    "Newsletters": 2,
    "Promotions": 1,
}

MANUAL_REVIEW_PATTERN = re.compile(
    r"\b("
    r"login|log in|logged in|sign-in|sign in|signed in|new device|verification code|verify|"
    r"security alert|security vulnerabilities|vulnerabilit|oauth application approval|"
    r"requesting updated permissions|password|passkey|two-factor|2fa|account.*(changed|change|updated|update)|"
    r"action needed|confirm your recent purchase|identity monitoring|declined|suspended|at risk"
    r")\b",
    re.IGNORECASE,
)


def run_gws_json(args):
    env = os.environ.copy()
    env.setdefault("GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND", "file")
    result = subprocess.run(
        ["gws", *args, "--format", "json"],
        check=False,
        capture_output=True,
        text=True,
        env=env,
    )
    if result.returncode != 0:
        sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)
    payload = result.stdout.strip()
    if not payload:
        return {}
    return json.loads(payload)


def fetch_message_detail(message_id):
    return run_gws_json(
        [
            "gmail",
            "users",
            "messages",
            "get",
            "--params",
            json.dumps(
                {
                    "userId": "me",
                    "id": message_id,
                    "format": "metadata",
                    "metadataHeaders": HEADER_NAMES,
                }
            ),
        ]
    )


def fetch_message_refs(query, sample):
    refs = []
    page_token = None

    while len(refs) < sample:
        params = {
            "userId": "me",
            "q": query,
            "maxResults": min(500, sample - len(refs)),
        }
        if page_token:
            params["pageToken"] = page_token

        payload = run_gws_json(
            ["gmail", "users", "messages", "list", "--params", json.dumps(params)]
        )
        refs.extend(payload.get("messages", []))
        page_token = payload.get("nextPageToken")
        if not page_token:
            break

    return refs[:sample]


def header_map(message):
    payload = message.get("payload", {})
    headers = payload.get("headers", [])
    return {header["name"].lower(): header["value"] for header in headers}


def normalize_sender(headers):
    raw = headers.get("from", "")
    name, email_addr = parseaddr(raw)
    email_addr = email_addr.lower().strip()
    domain = email_addr.split("@", 1)[1] if "@" in email_addr else ""
    name = name.strip().strip('"')
    return {
        "raw": raw,
        "name": name,
        "email": email_addr,
        "domain": domain,
    }


def normalize_list_id(value):
    value = (value or "").strip()
    if value.startswith("<") and value.endswith(">"):
        value = value[1:-1]
    return value.lower()


def load_protected_senders(path):
    protected = set()
    file_path = Path(path).expanduser()
    if file_path.exists():
        for line in file_path.read_text().splitlines():
            line = line.strip().lower()
            if line and not line.startswith("#"):
                protected.add(line)

    env_value = os.environ.get("GMAIL_ANALYZER_PROTECTED_SENDERS", "")
    for item in env_value.split(","):
        item = item.strip().lower()
        if item:
            protected.add(item)

    return protected


def requires_manual_review(sender, headers):
    subject = headers.get("subject", "")
    haystack = " ".join([sender["email"], sender["name"], subject]).lower()
    return bool(MANUAL_REVIEW_PATTERN.search(haystack))


def classify_message(sender, headers, label_names):
    subject = headers.get("subject", "")
    list_id = headers.get("list-id", "")
    list_unsubscribe = headers.get("list-unsubscribe", "")
    precedence = headers.get("precedence", "").lower()

    haystack = " ".join(
        [
            sender["email"],
            sender["domain"],
            sender["name"],
            subject,
            list_id,
        ]
    ).lower()

    if re.search(r"\b(dmarc|aggregate report|rua=|report domain)\b", haystack):
        return "Infra", "domain or security report"

    if re.search(r"\b(fedex|ups|usps|dhl|narvar|tripit|flight|itinerary|departure|arrival|travel|boarding|gate|baggage)\b", haystack):
        return "Logistics", "shipping or travel update"

    if re.search(r"\b(receipt|invoice|order|payment|renewal|subscription|statement|bill|billing)\b", haystack):
        return "Receipts", "billing or commerce keywords"

    if list_id or list_unsubscribe or precedence in {"bulk", "list", "junk"}:
        return "Newsletters", "mailing-list headers present"

    if re.search(r"\b(alert|notification|digest|summary|monitor|security|portal)\b", haystack):
        return "Notifications", "notification-style sender or subject"

    if "CATEGORY_PROMOTIONS" in label_names:
        return "Promotions", "already categorized by Gmail promotions"

    if "CATEGORY_UPDATES" in label_names:
        return "Updates", "already categorized by Gmail updates"

    if re.search(r"\b(noreply|no-reply|donotreply|do-not-reply)\b", haystack):
        return "Notifications", "no-reply sender"

    return None, None


def proposed_criteria(sender, headers):
    email_addr = sender["email"]
    list_id = normalize_list_id(headers.get("list-id", ""))
    if email_addr:
        return {"from": email_addr}
    if list_id:
        return {"query": f"list:{list_id}"}
    return None


def criteria_signature(criteria):
    if not criteria:
        return ""
    normalized = {key: criteria[key] for key in sorted(criteria) if criteria[key] not in (None, "", False)}
    return json.dumps(normalized, sort_keys=True, separators=(",", ":"))


def rule_signature(criteria, label_name, archive):
    return json.dumps(
        {
            "criteria": json.loads(criteria_signature(criteria) or "{}"),
            "label": label_name,
            "archive": bool(archive),
        },
        sort_keys=True,
        separators=(",", ":"),
    )


def choose_category(category_counts):
    return max(
        category_counts.items(),
        key=lambda item: (item[1], CATEGORY_PRIORITY.get(item[0], 0), item[0]),
    )[0]


def build_existing_filter_signatures(filters, label_id_to_name):
    signatures = set()
    for item in filters:
        criteria = item.get("criteria", {})
        action = item.get("action", {})
        archive = "INBOX" in action.get("removeLabelIds", [])
        add_ids = action.get("addLabelIds", [])
        if not add_ids:
            continue
        for label_id in add_ids:
            label_name = label_id_to_name.get(label_id, label_id)
            signatures.add(rule_signature(criteria, label_name, archive))
    return signatures


def main():
    parser = argparse.ArgumentParser(description="Analyze inbox patterns and suggest Gmail labels and filters.")
    parser.add_argument("--query", default="in:inbox", help="Gmail query to sample. Default: in:inbox.")
    parser.add_argument("--sample", type=int, default=100, help="Maximum messages to inspect. Default: 100.")
    parser.add_argument("--min-count", type=int, default=2, help="Minimum matches before proposing a rule. Default: 2.")
    parser.add_argument("--workers", type=int, default=8, help="Parallel metadata fetch workers. Default: 8.")
    parser.add_argument(
        "--min-confidence",
        type=float,
        default=0.6,
        help="Minimum dominant-category confidence before proposing a rule. Default: 0.6.",
    )
    parser.add_argument("--out-dir", default="~/.gws/analysis", help="Directory for analysis reports.")
    parser.add_argument(
        "--protected-senders-file",
        default="~/.gws/protected_senders.txt",
        help="Optional newline-delimited protected senders file. Default: ~/.gws/protected_senders.txt.",
    )
    args = parser.parse_args()

    out_dir = Path(args.out_dir).expanduser()
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    run_dir = out_dir / stamp
    run_dir.mkdir(parents=True, exist_ok=True)
    protected_senders = load_protected_senders(args.protected_senders_file)

    labels_payload = run_gws_json(
        ["gmail", "users", "labels", "list", "--params", json.dumps({"userId": "me"})]
    )
    filters_payload = run_gws_json(
        ["gmail", "users", "settings", "filters", "list", "--params", json.dumps({"userId": "me"})]
    )
    labels = labels_payload.get("labels", [])
    label_id_to_name = {item["id"]: item["name"] for item in labels}
    existing_filters = filters_payload.get("filter", [])
    existing_filter_signatures = build_existing_filter_signatures(existing_filters, label_id_to_name)
    message_refs = fetch_message_refs(args.query, args.sample)

    details = []
    sender_counter = Counter()
    domain_counter = Counter()
    grouped_candidates = defaultdict(list)
    protected_sender_hits = 0
    manual_review_hits = 0

    message_ids = [ref["id"] for ref in message_refs]
    messages_by_id = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=max(1, args.workers)) as executor:
        future_map = {
            executor.submit(fetch_message_detail, message_id): message_id
            for message_id in message_ids
        }
        for future in concurrent.futures.as_completed(future_map):
            message_id = future_map[future]
            messages_by_id[message_id] = future.result()

    for ref in message_refs:
        message = messages_by_id[ref["id"]]
        headers = header_map(message)
        sender = normalize_sender(headers)
        label_names = [label_id_to_name.get(item, item) for item in message.get("labelIds", [])]
        category, reason = classify_message(sender, headers, label_names)
        criteria = proposed_criteria(sender, headers)
        is_protected_sender = sender["email"] in protected_senders
        needs_manual_review = requires_manual_review(sender, headers)
        detail = {
            "id": message.get("id"),
            "threadId": message.get("threadId"),
            "subject": headers.get("subject", ""),
            "date": headers.get("date", ""),
            "sender": sender,
            "labels": label_names,
            "snippet": message.get("snippet", ""),
            "listId": headers.get("list-id", ""),
            "listUnsubscribe": headers.get("list-unsubscribe", ""),
            "category": category,
            "reason": reason,
            "criteria": criteria,
            "protectedSender": is_protected_sender,
            "manualReview": needs_manual_review,
        }
        details.append(detail)
        if sender["email"]:
            sender_counter[sender["email"]] += 1
        if sender["domain"]:
            domain_counter[sender["domain"]] += 1
        if is_protected_sender:
            protected_sender_hits += 1
            continue
        if needs_manual_review:
            manual_review_hits += 1
            continue
        if category and criteria:
            grouped_candidates[(category, criteria_signature(criteria))].append(detail)

    proposed_rules = []
    skipped_rules = []
    ambiguous_rules = []
    seen_rule_signatures = set()
    by_criteria = defaultdict(list)
    for (_, criteria_key), items in grouped_candidates.items():
        by_criteria[criteria_key].extend(items)

    for criteria_key, items in sorted(by_criteria.items()):
        count = len(items)
        if count < args.min_count:
            continue
        sample_item = items[0]
        criteria = sample_item["criteria"]
        category_counts = Counter(item["category"] for item in items if item["category"])
        if not category_counts:
            continue
        category = choose_category(category_counts)
        dominant_count = category_counts[category]
        confidence = dominant_count / count
        archive = category in {"Newsletters", "Receipts", "Notifications", "Promotions", "Updates", "Logistics", "Infra"}
        label_names = {
            name
            for item in items
            for name in item["labels"]
            if not name.startswith("CATEGORY_") and name not in {"INBOX", "UNREAD", "IMPORTANT", "STARRED"}
        }
        if label_names:
            category = sorted(label_names)[0]
            dominant_count = count
            confidence = 1.0
        signature = rule_signature(criteria, category, archive)
        if signature in seen_rule_signatures:
            continue
        seen_rule_signatures.add(signature)
        reason_counts = Counter(item["reason"] for item in items if item["reason"])
        record = {
            "label": category,
            "criteria": criteria,
            "archive": archive,
            "count": count,
            "reason": reason_counts.most_common(1)[0][0] if reason_counts else sample_item["reason"],
            "sender": sample_item["sender"]["raw"],
            "subject": sample_item["subject"],
            "existing_filter": signature in existing_filter_signatures,
            "confidence": round(confidence, 3),
            "category_counts": dict(sorted(category_counts.items())),
        }
        if record["existing_filter"]:
            skipped_rules.append(record)
        elif confidence < args.min_confidence:
            ambiguous_rules.append(record)
        else:
            proposed_rules.append(record)

    proposed_rules.sort(key=lambda item: (-item["confidence"], -item["count"], item["label"], criteria_signature(item["criteria"])))
    skipped_rules.sort(key=lambda item: (-item["confidence"], -item["count"], item["label"], criteria_signature(item["criteria"])))
    ambiguous_rules.sort(key=lambda item: (-item["count"], -item["confidence"], item["label"], criteria_signature(item["criteria"])))

    rules_payload = {
        "generated_at": stamp,
        "query": args.query,
        "rules": [
            {
                "label": item["label"],
                "criteria": item["criteria"],
                "archive": item["archive"],
            }
            for item in proposed_rules
        ],
    }

    report_lines = []
    report_lines.append(f"# Gmail inbox analysis ({stamp})")
    report_lines.append("")
    report_lines.append(f"- Query: `{args.query}`")
    report_lines.append(f"- Sample size: {len(details)} messages")
    report_lines.append(f"- Existing user labels: {sum(1 for item in labels if item.get('type') == 'user')}")
    report_lines.append(f"- Existing filters: {len(existing_filters)}")
    report_lines.append(f"- Proposed new rules: {len(proposed_rules)}")
    report_lines.append(f"- Skipped because similar filter already exists: {len(skipped_rules)}")
    report_lines.append(f"- Ambiguous candidates below confidence threshold: {len(ambiguous_rules)}")
    report_lines.append(f"- Protected-sender messages excluded from rule generation: {protected_sender_hits}")
    report_lines.append(f"- Manual-review messages excluded from rule generation: {manual_review_hits}")
    report_lines.append("")

    report_lines.append("## Top senders")
    report_lines.append("")
    for sender, count in sender_counter.most_common(20):
        report_lines.append(f"- {sender}: {count}")
    report_lines.append("")

    report_lines.append("## Candidate rules")
    report_lines.append("")
    if proposed_rules:
        for item in proposed_rules:
            archive_text = "skip inbox" if item["archive"] else "keep in inbox"
            report_lines.append(
                f"- `{json.dumps(item['criteria'], sort_keys=True)}` -> label `{item['label']}`, {archive_text}. "
                f"{item['count']} matches, confidence {item['confidence']:.0%}. Reason: {item['reason']}. "
                f"Example: {item['sender']} / {item['subject']}"
            )
    else:
        report_lines.append("- No obvious new candidates found in this sample.")
    report_lines.append("")

    report_lines.append("## Already covered by existing filters")
    report_lines.append("")
    if skipped_rules:
        for item in skipped_rules:
            report_lines.append(
                f"- `{json.dumps(item['criteria'], sort_keys=True)}` already appears covered for label `{item['label']}`. "
                f"{item['count']} matches. Example: {item['sender']} / {item['subject']}"
            )
    else:
        report_lines.append("- No candidate rules were skipped for existing-filter overlap.")
    report_lines.append("")

    report_lines.append("## Ambiguous candidates")
    report_lines.append("")
    if ambiguous_rules:
        for item in ambiguous_rules[:25]:
            report_lines.append(
                f"- `{json.dumps(item['criteria'], sort_keys=True)}` had mixed categories {json.dumps(item['category_counts'], sort_keys=True)}. "
                f"Top label `{item['label']}` only reached {item['confidence']:.0%} confidence."
            )
    else:
        report_lines.append("- No ambiguous candidates.")
    report_lines.append("")

    report_lines.append("## Existing non-system labels")
    report_lines.append("")
    for label in sorted((item["name"] for item in labels if item.get("type") == "user"), key=str.lower):
        report_lines.append(f"- {label}")
    report_lines.append("")

    report_lines.append("## Next step")
    report_lines.append("")
    report_lines.append(f"- Review: `{run_dir / 'rules.json'}`")
    report_lines.append(f"- Dry run: `gmail-filter-apply {run_dir / 'rules.json'}`")
    report_lines.append(f"- Apply: `gmail-filter-apply --apply {run_dir / 'rules.json'}`")

    report_path = run_dir / "report.md"
    summary_path = run_dir / "summary.json"
    rules_path = run_dir / "rules.json"
    report_path.write_text("\n".join(report_lines) + "\n")
    summary_path.write_text(
        json.dumps(
            {
                "query": args.query,
                "sample_size": len(details),
                "top_senders": sender_counter.most_common(50),
                "top_domains": domain_counter.most_common(50),
                "existing_filter_count": len(existing_filters),
                "existing_labels": sorted(
                    [item["name"] for item in labels if item.get("type") == "user"],
                    key=str.lower,
                ),
                "protected_senders": sorted(protected_senders),
                "protected_sender_hits": protected_sender_hits,
                "manual_review_hits": manual_review_hits,
                "proposed_rules": proposed_rules,
                "skipped_existing_rules": skipped_rules,
                "ambiguous_rules": ambiguous_rules,
                "messages": details,
            },
            indent=2,
        )
    )
    rules_path.write_text(json.dumps(rules_payload, indent=2) + "\n")

    print(report_path)


if __name__ == "__main__":
    main()
