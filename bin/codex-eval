#!/usr/bin/env bash
set -euo pipefail

EVAL_ROOT="${HOME}/.codex/evals"
PROMPT_ROOT="${EVAL_ROOT}/prompts"
DEFAULT_WORKDIR="${PWD}"
RUN_ROOT="${HOME}/.codex/eval-runs"

usage() {
  cat <<'EOF'
Usage: codex-eval [--all] [--variant NAME] [--prompt FILE] [--workdir DIR] [--out DIR]

Options:
  --all            Run the full suite across all variants
  --variant NAME   One of: with-global-instructions, minimal-global-instructions
  --prompt FILE    Specific prompt file to run (repeatable)
  --workdir DIR    Repo/workdir for codex exec
  --out DIR        Output directory (default: ~/.codex/eval-runs/<timestamp>)
EOF
}

variants=(with-global-instructions minimal-global-instructions)
selected_variants=()
selected_prompts=()
workdir="${DEFAULT_WORKDIR}"
out_dir=""

metadata_value() {
  local prompt_file="$1"
  local key="$2"

  sed -n "s/^<!-- codex-eval-${key}: \\(.*\\) -->$/\\1/p" "${prompt_file}" | head -n 1
}

compose_prompt() {
  local prompt_file="$1"
  local composed="$2"

  sed '/^<!-- codex-eval-[a-z0-9-]*: .* -->$/d' "${prompt_file}" > "${composed}"
}

prepare_fixture_workspace() {
  local fixture_name="$1"
  local workspace="$2"
  local fixture_root="${EVAL_ROOT}/fixtures/${fixture_name}"

  if [[ ! -d "${fixture_root}" ]]; then
    echo "Missing fixture repo: ${fixture_root}" >&2
    exit 1
  fi

  rm -rf "${workspace}"
  mkdir -p "${workspace}"
  cp -R "${fixture_root}/." "${workspace}/"
  chmod -R u+w "${workspace}"

  (
    cd "${workspace}"
    git init -q
    git config user.name "Codex Eval"
    git config user.email "codex-eval@example.com"
    git add -A
    git commit -q -m "fixture baseline"
  )
}

record_fixture_artifacts() {
  local workspace="$1"
  local status_file="$2"
  local diff_stat_file="$3"
  local diff_file="$4"

  (
    cd "${workspace}"
    git status --short
  ) > "${status_file}"

  (
    cd "${workspace}"
    git diff --stat HEAD
  ) > "${diff_stat_file}"

  (
    cd "${workspace}"
    git diff HEAD
  ) > "${diff_file}"
}

run_post_check() {
  local workspace="$1"
  local post_check="$2"
  local post_check_file="$3"
  local post_check_exit=0

  set +e
  (
    cd "${workspace}"
    /bin/bash -lc "${post_check}"
  ) > "${post_check_file}" 2>&1
  post_check_exit=$?
  set -e

  printf '\n[exit_code=%s]\n' "${post_check_exit}" >> "${post_check_file}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)
      selected_variants=("${variants[@]}")
      shift
      ;;
    --variant)
      selected_variants+=("$2")
      shift 2
      ;;
    --prompt)
      selected_prompts+=("$2")
      shift 2
      ;;
    --workdir)
      workdir="$2"
      shift 2
      ;;
    --out)
      out_dir="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown arg: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ ${#selected_variants[@]} -eq 0 ]]; then
  selected_variants=("${variants[@]}")
fi

if [[ ${#selected_prompts[@]} -eq 0 ]]; then
  while IFS= read -r file; do
    selected_prompts+=("$file")
  done < <(find "${PROMPT_ROOT}" -type f -name '*.md' | sort)
fi

if [[ -z "${out_dir}" ]]; then
  timestamp="$(date +%Y%m%dT%H%M%S)"
  out_dir="${RUN_ROOT}/${timestamp}"
fi

mkdir -p "${out_dir}"
mkdir -p "${out_dir}/runs"

scorecard="${out_dir}/scorecard.csv"
manifest="${out_dir}/manifest.csv"

printf 'variant,prompt_id,category,output_file,events_file,stderr_file\n' > "${manifest}"
printf 'variant,prompt_id,category,naturalness,concision,correctness,directness,willingness_to_act,non_annoyingness,notes\n' > "${scorecard}"

instruction_file_for_variant() {
  case "$1" in
    with-global-instructions) echo "${HOME}/.codex/AGENTS.md" ;;
    minimal-global-instructions) echo "${EVAL_ROOT}/instructions/empty.md" ;;
    *)
      echo "Unknown variant: $1" >&2
      exit 1
      ;;
  esac
}

run_one() {
  local variant="$1"
  local prompt_file="$2"
  local instruction_file
  instruction_file="$(instruction_file_for_variant "${variant}")"

  local category prompt_base prompt_id run_dir composed output_file events_file stderr_file
  local fixture_name sandbox post_check effective_workdir workspace
  local status_file diff_stat_file diff_file post_check_file
  category="$(basename "$(dirname "${prompt_file}")")"
  prompt_base="$(basename "${prompt_file}" .md)"
  prompt_id="${category}__${prompt_base}"
  run_dir="${out_dir}/runs/${variant}/${category}"
  mkdir -p "${run_dir}"

  composed="${run_dir}/${prompt_base}.prompt.md"
  output_file="${run_dir}/${prompt_base}.last.md"
  events_file="${run_dir}/${prompt_base}.events.jsonl"
  stderr_file="${run_dir}/${prompt_base}.stderr.log"

  compose_prompt "${prompt_file}" "${composed}"

  fixture_name="$(metadata_value "${prompt_file}" "fixture")"
  sandbox="$(metadata_value "${prompt_file}" "sandbox")"
  post_check="$(metadata_value "${prompt_file}" "post-check")"
  effective_workdir="${workdir}"

  if [[ -n "${fixture_name}" ]]; then
    workspace="${run_dir}/${prompt_base}.workspace"
    prepare_fixture_workspace "${fixture_name}" "${workspace}"
    effective_workdir="${workspace}"
    if [[ -z "${sandbox}" ]]; then
      sandbox="workspace-write"
    fi
  fi

  if [[ -z "${sandbox}" ]]; then
    sandbox="read-only"
  fi

  echo "[${variant}] ${prompt_id}" >&2
  codex exec \
    --ephemeral \
    --skip-git-repo-check \
    --sandbox "${sandbox}" \
    -C "${effective_workdir}" \
    -c "model_instructions_file=\"${instruction_file}\"" \
    --json \
    -o "${output_file}" \
    - < "${composed}" > "${events_file}" 2> "${stderr_file}"

  if [[ -n "${fixture_name}" ]]; then
    status_file="${run_dir}/${prompt_base}.status.txt"
    diff_stat_file="${run_dir}/${prompt_base}.diffstat.txt"
    diff_file="${run_dir}/${prompt_base}.diff.txt"
    record_fixture_artifacts "${workspace}" "${status_file}" "${diff_stat_file}" "${diff_file}"

    if [[ -n "${post_check}" ]]; then
      post_check_file="${run_dir}/${prompt_base}.post-check.log"
      run_post_check "${workspace}" "${post_check}" "${post_check_file}"
    fi
  fi

  printf '%s,%s,%s,%s,%s,%s\n' \
    "${variant}" "${prompt_id}" "${category}" "${output_file}" "${events_file}" "${stderr_file}" >> "${manifest}"
  printf '%s,%s,%s,,,,,,,\n' "${variant}" "${prompt_id}" "${category}" >> "${scorecard}"
}

for variant in "${selected_variants[@]}"; do
  for prompt_file in "${selected_prompts[@]}"; do
    run_one "${variant}" "${prompt_file}"
  done
done

echo "Wrote eval run to ${out_dir}"
