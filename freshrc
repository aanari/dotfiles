prune_stale_fresh_targets() {
	local stale_paths=(
		~/.screenrc
		~/.config/browsh
		~/.config/terminator/config
		~/.pentadactyl/colors/solarized-light.penta
		~/.vimrc
		~/.vim/after
	)

	local stale_path
	for stale_path in "${stale_paths[@]}"; do
		if [ -e "$stale_path" ] || [ -L "$stale_path" ]; then
			rm -rf "$stale_path"
		fi
	done

	if [ -d ~/.vim/bundle ] && [ -w ~/.vim/bundle ]; then
		rm -rf ~/.vim/bundle
	fi

}

prune_stale_fresh_targets

migrate_nvim_v25() {
	local targets=(
		~/.config/nvim/init.lua
		~/.config/nvim/lua/autocmds.lua
		~/.config/nvim/lua/chadrc.lua
		~/.config/nvim/lua/commands.lua
		~/.config/nvim/lua/highlights.lua
		~/.config/nvim/lua/mappings.lua
		~/.config/nvim/lua/nvchad/cmp.lua
		~/.config/nvim/lua/options.lua
		~/.config/nvim/lua/configs/cmp.lua
		~/.config/nvim/lua/configs/lazy.lua
		~/.config/nvim/lua/configs/lspconfig.lua
		~/.config/nvim/lua/configs/mason.lua
		~/.config/nvim/lua/configs/none-ls.lua
		~/.config/nvim/lua/configs/nvimtree.lua
		~/.config/nvim/lua/configs/treesitter.lua
		~/.config/nvim/lua/plugins/init.lua
	)

	for target in "${targets[@]}"; do
		if [ -e "$target" ] && [ ! -L "$target" ]; then
			rm -f "$target"
		fi
	done

	local stale_paths=(
		~/.config/nvim/.git
		~/.config/nvim/.github
		~/.config/nvim/.gitignore
		~/.config/nvim/.ignore
		~/.config/nvim/.stylua.toml
		~/.config/nvim/LICENSE
		~/.config/nvim/lua/custom
		~/.config/nvim/lua/nvconfig.lua
		~/.config/nvim/lua/core
		~/.config/nvim/lua/plugins/configs
	)

	for path in "${stale_paths[@]}"; do
		if [ -e "$path" ] || [ -L "$path" ]; then
			rm -rf "$path"
		fi
	done
}

migrate_nvim_v25

