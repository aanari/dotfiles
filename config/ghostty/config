background = #FAFAFA
foreground = #383A42
window-theme = light
selection-background = #DADADB
selection-foreground = #383A42

palette = 0=#383A42
palette = 1=#D84A3D
palette = 2=#50A14F
palette = 3=#C18401
palette = 4=#4078F2
palette = 5=#A626A4
palette = 6=#0070A8
palette = 7=#FAFAFA
palette = 8=#A2A2A3
palette = 9=#F07178
palette = 10=#7ECA9C
palette = 11=#DEA95F
palette = 12=#428BAB
palette = 13=#8E79B9
palette = 14=#519ABA
palette = 15=#54555B

font-family = ""
font-family = "PragmataPro Mono Liga"
font-family = "Apple Color Emoji"
font-family = "azuki_font"
window-title-font-family = "PragmataPro Mono Liga"
font-size = 18
font-thicken = false

cursor-style = block
cursor-style-blink = true
cursor-opacity = 1
cursor-click-to-move = true

shell-integration = zsh
shell-integration-features = cursor,title,sudo,ssh-env,ssh-terminfo,path

clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
copy-on-select = false

scrollbar = never
window-width = 180
window-height = 48
window-padding-x = 1
window-padding-y = 0
window-padding-balance = false
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true
window-new-tab-position = end

background-opacity = 0.85
background-opacity-cells = false
background-blur = false

confirm-close-surface = false
quit-after-last-window-closed = true
window-decoration = auto

macos-titlebar-style = tabs
macos-option-as-alt = false
macos-non-native-fullscreen = true
macos-icon = chalkboard
auto-update = download

mouse-hide-while-typing = true

# Keybinds to match WezTerm muscle memory
# Send raw ESC for ctrl+[ so it works as <Esc> in vim/neovim under the kitty protocol
keybind = ctrl+left_bracket=text:\x1b
keybind = ctrl+l=clear_screen
keybind = f11=toggle_fullscreen
keybind = cmd+alt+left=previous_tab
keybind = cmd+alt+right=next_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = shift+home=scroll_to_top
keybind = shift+end=scroll_to_bottom
keybind = shift+insert=paste_from_selection
