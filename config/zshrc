typeset -gi ZSH_HAS_TTY=0
[[ -t 0 && -t 1 ]] && ZSH_HAS_TTY=1

# Enable Powerlevel10k instant prompt only when attached to a real tty.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if (( ZSH_HAS_TTY )) && [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Bootstrap zinit (must be before any zinit commands)
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

_zinit_snippet_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/snippets"
_zinit_plugin_dir="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/plugins"

compile_zsh_source() {
  local source_path="$1"
  local compiled_path="${source_path}.zwc"

  [[ -r "$source_path" ]] || return 1

  if [[ ! -r "$compiled_path" || "$source_path" -nt "$compiled_path" ]]; then
    zcompile -- "$source_path" 2>/dev/null
  fi
}

source_zinit_snippet() {
  local snippet="$1"
  local relpath="$2"
  local snippet_path="${_zinit_snippet_dir}/${snippet}/${relpath}"

  if [[ -r "${snippet_path}" ]]; then
    compile_zsh_source "${snippet_path}"
    source "${snippet_path}"
  else
    zinit snippet "${snippet}"
  fi
}

source_zinit_plugin() {
  local repo="$1"
  local relpath="$2"
  local plugin_path="${_zinit_plugin_dir}/${repo/\//---}/${relpath}"

  if [[ -r "${plugin_path}" ]]; then
    compile_zsh_source "${plugin_path}"
    source "${plugin_path}"
  else
    zinit light "${repo}"
  fi
}

if (( ZSH_HAS_TTY )); then
  # Load Powerlevel10k theme.
  source_zinit_plugin romkatv/powerlevel10k powerlevel10k.zsh-theme
fi

[[ -f ~/.fresh/build/shell.sh ]] && . ~/.fresh/build/shell.sh

# zinit annexes
zinit light-mode for \
    zdharma-continuum/zinit-annex-bin-gem-node \
    zdharma-continuum/zinit-annex-patch-dl

# Configure Prezto modules before loading
zstyle ':prezto:*:*' color 'yes'
zstyle ':prezto:module:editor' key-bindings 'vi'
zstyle ':prezto:module:editor' dot-expansion 'yes'

# Disable auto-title in tmux to prevent hostname from appearing.
if (( ZSH_HAS_TTY )) && [[ -n "$TMUX" ]]; then
  zstyle ':prezto:module:terminal' auto-title 'no'
  # Set pane title to current directory in tmux
  autoload -Uz add-zsh-hook
  function set_tmux_pane_title() {
    printf '\033]2;%s\007' "${PWD##*/}"
  }
  # Set it initially and on directory change
  set_tmux_pane_title
  add-zsh-hook chpwd set_tmux_pane_title
else
  zstyle ':prezto:module:terminal' auto-title 'yes'
  zstyle ':prezto:module:terminal:window-title' format '%n@%m: %s'
  zstyle ':prezto:module:terminal:tab-title' format '%m: %s'
fi

# Cache completion initialization
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.cache/zsh/completions
# Fuzzy completion matching
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}' 'r:|=*' 'l:|=* r:|=*'
# Faster git completion
[[ -r ~/.cache/zsh/git-completion.bash ]] && zstyle ':completion:*:*:git:*' script ~/.cache/zsh/git-completion.bash

# Enhanced history settings
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_FIND_NO_DUPS
setopt HIST_VERIFY
setopt INC_APPEND_HISTORY_TIME

# Load Prezto modules from cached snippets when available.
source_zinit_snippet PZTM::environment PZTM::environment
# Don't load terminal module in tmux or non-tty shells.
(( ZSH_HAS_TTY )) && [[ -z "$TMUX" ]] && source_zinit_snippet PZTM::terminal PZTM::terminal
source_zinit_snippet PZTM::editor PZTM::editor
source_zinit_snippet PZTM::history PZTM::history
source_zinit_snippet PZTM::directory PZTM::directory
source_zinit_snippet PZTM::utility PZTM::utility

# Git module - use built-in git aliases instead of svn
source_zinit_snippet PZTM::git/alias.zsh alias.zsh

if (( ZSH_HAS_TTY )); then
  # Load history substring search early (before vi-mode).
  source_zinit_plugin zsh-users/zsh-history-substring-search zsh-history-substring-search.plugin.zsh
  zle -N history-substring-search-up
  zle -N history-substring-search-down

  # Syntax highlighting.
  ZINIT[COMPINIT_OPTS]=-C
  zicompinit
  zicdreplay
  source_zinit_plugin zdharma-continuum/fast-syntax-highlighting fast-syntax-highlighting.plugin.zsh

  # Autosuggestions.
  source_zinit_plugin zsh-users/zsh-autosuggestions zsh-autosuggestions.plugin.zsh
  (( $+functions[_zsh_autosuggest_start] )) && _zsh_autosuggest_start
fi

# Additional completions
zinit ice wait"0" lucid blockf atpull'zinit creinstall -q .'
zinit light zsh-users/zsh-completions

if (( ZSH_HAS_TTY )); then
  # Plugins.
  zinit ice wait"0" lucid
  zinit pack="bgn-binary+keys" for fzf
  [[ -r "${_zinit_plugin_dir}/fzf/key-bindings.zsh" ]] && source "${_zinit_plugin_dir}/fzf/key-bindings.zsh"
  if (( $+functions[fzf-history-widget] )); then
    bindkey -M emacs '^R' fzf-history-widget
    bindkey -M viins '^R' fzf-history-widget
    bindkey -M vicmd '^R' fzf-history-widget
  fi

  source_zinit_plugin Aloxaf/fzf-tab fzf-tab.plugin.zsh

  # Configure zsh-vi-mode before loading.
  ZVM_LINE_INIT_MODE=$ZVM_MODE_INSERT
  ZVM_VI_INSERT_ESCAPE_BINDKEY=jk

  # Load zsh-vi-mode eagerly for immediate cursor feedback.
  source_zinit_plugin jeffreytse/zsh-vi-mode zsh-vi-mode.plugin.zsh

  # Load OSC52 clipboard integration for vi-mode.
  if [[ -f ~/.dotfiles/config/zsh/vi-mode-clipboard.zsh ]]; then
    source ~/.dotfiles/config/zsh/vi-mode-clipboard.zsh
  fi

  # Define after_init function to preserve our bindings.
  zvm_after_init() {
    (( $+functions[fzf-history-widget] )) && {
      bindkey -M emacs '^R' fzf-history-widget
      bindkey -M viins '^R' fzf-history-widget
      bindkey -M vicmd '^R' fzf-history-widget
    }
    bindkey -M emacs '^[[A' history-substring-search-up
    bindkey -M emacs '^[[B' history-substring-search-down
    bindkey -M vicmd 'k' history-substring-search-up
    bindkey -M vicmd 'j' history-substring-search-down
    bindkey -M vicmd '^[[A' history-substring-search-up
    bindkey -M vicmd '^[[B' history-substring-search-down
    bindkey -M viins '^[[A' history-substring-search-up
    bindkey -M viins '^[[B' history-substring-search-down
  }
fi

# tldr
zinit ice wait"2" as"command" pick"tldr" lucid
zinit light raylee/tldr

# git-cal
zinit wait"2" lucid as"null" \
 atclone'perl Makefile.PL PREFIX=$ZPFX' \
 atpull'%atclone' make sbin"git-cal" for \
    k4rthik/git-cal

zinit wait"1" lucid from"gh-r" as"null" for \
     sbin"**/bat"         @sharkdp/bat \
     sbin"**/fd"          @sharkdp/fd \
     sbin"**/hyperfine"   @sharkdp/hyperfine \
     sbin"**/rg"          @BurntSushi/ripgrep \
     sbin"**/delta"       @dandavison/delta \
     sbin"**/dust"        @bootandy/dust \
     sbin"**/just"        @casey/just

# yank, clipboard
zinit ice as"program" pick"yank" make
zinit light mptre/yank

# direnv
#zinit as"program" make'!' atclone'./direnv hook zsh > zhook.zsh' \
#  atpull'%atclone' pick"direnv" src"zhook.zsh" for \
#  direnv/direnv

# fzf-tab configuration
# disable sort when completing `git checkout`
zstyle ':completion:*:git-checkout:*' sort false
# set descriptions format to enable group support
zstyle ':completion:*:descriptions' format '[%d]'
# set list-colors to enable filename colorizing
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# preview directory's content with lsd when completing cd
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'lsd -l -F --group-directories-first --color always --header --icon always --blocks permission,name  --size short $realpath | head -100'
# switch group using `,` and `.`
zstyle ':fzf-tab:*' switch-group ',' '.'


# dircolors
test -r ~/.dir_colors && eval $(dircolors ~/.dir_colors)

# Load interactive shell helpers.
for shell_file in alias editor filters functions; do
  shell_file_path="${DOTFILES:-$HOME/.dotfiles}/shell/${shell_file}"
  [[ -r "$shell_file_path" ]] && source "$shell_file_path"
done
unset shell_file shell_file_path

if (( ZSH_HAS_TTY )); then
  [[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
fi

# WSL specific things
if grep --quiet microsoft /proc/version 2>/dev/null; then
  # Set Windows display for WSL
  export DISPLAY=$(cat /etc/resolv.conf | grep nameserver | awk '{print $2; exit;}')':0.0'
  export LIBGL_ALWAYS_INDIRECT=1
fi

if (( ZSH_HAS_TTY )); then
  [[ -r ~/.fzf.sh ]] && source ~/.fzf.sh
fi

# Misc
export GIT_PAGER="delta"
alias cat="bat"
alias ls="lsd"
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=15'
# Configure cursor shapes for different vim modes
ZVM_INSERT_MODE_CURSOR=$ZVM_CURSOR_BLINKING_BEAM
ZVM_NORMAL_MODE_CURSOR=$ZVM_CURSOR_BLOCK
ZVM_VISUAL_MODE_CURSOR=$ZVM_CURSOR_BLOCK
ZVM_VISUAL_LINE_MODE_CURSOR=$ZVM_CURSOR_BLOCK
ZVM_OPPEND_MODE_CURSOR=$ZVM_CURSOR_UNDERLINE

export EDITOR='nvim'
unsetopt PATH_DIRS

# Additional vi mode settings
export KEYTIMEOUT=1

if (( ZSH_HAS_TTY )); then
  eval "$(direnv hook zsh)"
  eval "$(zoxide init zsh)"
fi

# Compile zcompdump, if modified, to increase startup speed.
zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
if [[ -f "$zcompdump" && "$zcompdump" -nt /usr/share/zsh ]] && ! [[ -f "$zcompdump.zwc" ]] || [[ "$zcompdump" -nt "$zcompdump.zwc" ]]; then
  zcompile "$zcompdump"
fi

unset _zinit_plugin_dir _zinit_snippet_dir
unfunction compile_zsh_source source_zinit_plugin source_zinit_snippet 2>/dev/null
